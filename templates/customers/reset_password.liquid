<div class="page-width">
  <div class="auth-card">
    <h1>Reset password</h1>
    <p>Set a new password for your account.</p>
    {% form 'reset_customer_password' %}
      {%- if form.errors -%}<div class="form-status form-status--error">{{ form.errors | default_errors }}</div>{%- endif -%}
      <div class="field"><label>New password</label><input type="password" name="customer[password]" autocomplete="new-password" required></div>
      <div class="field"><label>Confirm password</label><input type="password" name="customer[password_confirmation]" autocomplete="new-password" required></div>
      <button type="submit" class="btn btn--primary btn--full">Save password</button>
    {% endform %}
  </div>
</div>
