[
  {
    "name": "theme_info",
    "theme_name": "Flash Fashion",
    "theme_version": "1.0.0",
    "theme_author": "Flash Fashion",
    "theme_documentation_url": "https://flashfashion.com",
    "theme_support_email": "info@flashfashion.com"
  },
  {
    "name": "Logo",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo image"
      },
      {
        "type": "range",
        "id": "logo_width",
        "label": "Logo width (px)",
        "min": 80,
        "max": 320,
        "step": 10,
        "default": 160,
        "unit": "px"
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon",
        "info": "32x32 PNG recommended"
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "header",
        "content": "Foundation"
      },
      {
        "type": "color",
        "id": "color_background",
        "label": "Background",
        "default": "#08080F"
      },
      {
        "type": "color",
        "id": "color_surface",
        "label": "Surface (cards, inputs)",
        "default": "#12121C"
      },
      {
        "type": "color",
        "id": "color_foreground",
        "label": "Foreground (text)",
        "default": "#FFFFFF"
      },
      {
        "type": "color",
        "id": "color_muted",
        "label": "Muted text",
        "default": "#9A9AAE"
      },
      {
        "type": "color",
        "id": "color_border",
        "label": "Border",
        "default": "#26263A"
      },
      {
        "type": "header",
        "content": "Neon accents"
      },
      {
        "type": "color",
        "id": "color_accent_primary",
        "label": "Primary neon",
        "default": "#FF2D87"
      },
      {
        "type": "color",
        "id": "color_accent_secondary",
        "label": "Secondary neon",
        "default": "#00F0FF"
      },
      {
        "type": "color",
        "id": "color_accent_tertiary",
        "label": "Tertiary neon",
        "default": "#C6FF00"
      },
      {
        "type": "checkbox",
        "id": "enable_holographic",
        "label": "Enable holographic gradient on accents",
        "default": true
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Heading font",
        "default": "playfair_display_n7"
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Body font",
        "default": "inter_n4"
      },
      {
        "type": "range",
        "id": "heading_scale",
        "label": "Heading scale",
        "min": 90,
        "max": 130,
        "step": 5,
        "default": 110,
        "unit": "%"
      },
      {
        "type": "range",
        "id": "body_scale",
        "label": "Body scale",
        "min": 90,
        "max": 120,
        "step": 5,
        "default": 100,
        "unit": "%"
      },
      {
        "type": "checkbox",
        "id": "uppercase_headings",
        "label": "Uppercase headings",
        "default": false
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "page_width",
        "label": "Page width",
        "min": 1200,
        "max": 1800,
        "step": 50,
        "default": 1500,
        "unit": "px"
      },
      {
        "type": "range",
        "id": "section_spacing",
        "label": "Section spacing",
        "min": 40,
        "max": 160,
        "step": 8,
        "default": 96,
        "unit": "px"
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Cart type",
        "options": [
          { "value": "drawer", "label": "Drawer" },
          { "value": "page", "label": "Page" }
        ],
        "default": "drawer"
      },
      {
        "type": "checkbox",
        "id": "show_cart_note",
        "label": "Allow order notes",
        "default": true
      }
    ]
  },
  {
    "name": "Product cards",
    "settings": [
      {
        "type": "select",
        "id": "card_image_ratio",
        "label": "Image ratio",
        "options": [
          { "value": "portrait", "label": "Portrait (3:4)" },
          { "value": "square", "label": "Square (1:1)" },
          { "value": "landscape", "label": "Landscape (4:3)" }
        ],
        "default": "portrait"
      },
      {
        "type": "checkbox",
        "id": "card_show_second_image",
        "label": "Show second image on hover",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "card_show_vendor",
        "label": "Show vendor",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "card_quick_add",
        "label": "Quick add button",
        "default": true
      }
    ]
  },
  {
    "name": "Social",
    "settings": [
      { "type": "text", "id": "social_instagram", "label": "Instagram URL" },
      { "type": "text", "id": "social_tiktok", "label": "TikTok URL" },
      { "type": "text", "id": "social_youtube", "label": "YouTube URL" },
      { "type": "text", "id": "social_facebook", "label": "Facebook URL" },
      { "type": "text", "id": "social_twitter", "label": "Twitter / X URL" }
    ]
  },
  {
    "name": "Social sharing",
    "settings": [
      {
        "type": "image_picker",
        "id": "share_image",
        "label": "Default sharing image"
      }
    ]
  }
]
