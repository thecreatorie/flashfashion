<section class="section">
  <div class="page-width">
    <div class="section-head--center">
      {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 style="margin-top: 22px;">{{ section.settings.heading }}</h2>{%- endif -%}
    </div>

    <div class="ribbon">
      {%- for block in section.blocks -%}
        <div class="feat" {{ block.shopify_attributes }}>
          {%- if block.settings.icon != blank -%}<span class="icon">{{ block.settings.icon }}</span>{%- endif -%}
          {%- if block.settings.heading != blank -%}<h4>{{ block.settings.heading }}</h4>{%- endif -%}
          {%- if block.settings.text != blank -%}<p>{{ block.settings.text }}</p>{%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Features ribbon",
  "max_blocks": 8,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Why Flash" },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>Festival-grade.<br><em>Stage-ready.</em></p>" }
  ],
  "blocks": [
    {
      "type": "feat",
      "name": "Feature",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (emoji or symbol)", "default": "✦" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Hand-sewn" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Every silk fan stitched by hand. No two are exactly alike." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Features ribbon",
      "blocks": [
        { "type": "feat", "settings": { "icon": "🪡", "heading": "Hand-sewn", "text": "Every silk fan stitched by hand. No two are exactly alike." } },
        { "type": "feat", "settings": { "icon": "✦", "heading": "Same grip", "text": "Slip them over your fire fans — same Russian grip, in silk." } },
        { "type": "feat", "settings": { "icon": "⚡", "heading": "UV + Holo", "text": "Reactive under blacklight. Holographic crowns shift color with every angle." } },
        { "type": "feat", "settings": { "icon": "🛡️", "heading": "Firesafe", "text": "Slitweave bodysuits in natural fibers. Built for performers under fire." } }
      ]
    }
  ]
}
{% endschema %}
