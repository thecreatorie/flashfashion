<div class="page-width section">
  <a href="{{ routes.account_url }}" class="text-muted" style="font-size:0.85rem; text-decoration:underline; text-underline-offset:3px;">← Back to account</a>
  <header style="display:flex; justify-content:space-between; flex-wrap:wrap; gap:1rem; margin-block: 1rem 2rem;">
    <h1>Order #{{ order.name }}</h1>
    <div class="text-muted">{{ order.created_at | date: '%b %-d, %Y' }}</div>
  </header>

  <div style="display:grid; grid-template-columns: 1.5fr 1fr; gap:2rem;" class="order-grid">
    <section>
      <h3 class="mb-2" style="font-size:1.1rem;">Items</h3>
      {%- for line in order.line_items -%}
        <div class="cart-page__row">
          <div class="cart-page__media">
            {%- if line.image -%}{%- assign co_alt = line.title | escape -%}{%- assign co_url = line.image | image_url: width: 200 -%}{{ co_url | image_tag: alt: co_alt, width: 100, height: 133 }}{%- endif -%}
          </div>
          <div>
            <strong>{{ line.title }}</strong>
            <div class="text-muted" style="font-size:0.85rem;">Qty {{ line.quantity }}</div>
            {%- if line.fulfillment -%}<div class="text-muted" style="font-size:0.8rem;">{{ line.fulfillment.tracking_company }} {{ line.fulfillment.tracking_number }}</div>{%- endif -%}
          </div>
          <div></div>
          <div><strong>{{ line.final_line_price | money }}</strong></div>
        </div>
      {%- endfor -%}
    </section>

    <aside>
      <div style="background:var(--color-surface); border:1px solid var(--color-border); padding:1.5rem; border-radius:8px;">
        <h3 class="mb-2" style="font-size:1.05rem;">Summary</h3>
        <div style="display:flex; justify-content:space-between;"><span>Subtotal</span><span>{{ order.subtotal_price | money }}</span></div>
        <div style="display:flex; justify-content:space-between;"><span>Shipping</span><span>{{ order.shipping_price | money }}</span></div>
        <div style="display:flex; justify-content:space-between;"><span>Tax</span><span>{{ order.tax_price | money }}</span></div>
        <hr style="border:0; border-top:1px solid var(--color-border); margin: 0.6rem 0;">
        <div style="display:flex; justify-content:space-between;"><strong>Total</strong><strong>{{ order.total_price | money }}</strong></div>
      </div>

      {%- if order.shipping_address -%}
        <div style="background:var(--color-surface); border:1px solid var(--color-border); padding:1.5rem; border-radius:8px; margin-top:1rem;">
          <h3 class="mb-2" style="font-size:1.05rem;">Shipping</h3>
          <div class="text-muted">{{ order.shipping_address | format_address }}</div>
        </div>
      {%- endif -%}
    </aside>
  </div>
</div>
