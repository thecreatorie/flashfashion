<footer class="footer" role="contentinfo">
  <div class="page-width">
    <div class="footer__grid">
      <div class="footer__brand">
        <a class="header__logo" href="{{ routes.root_url }}">
          {%- if settings.logo != blank -%}
            {{ settings.logo | image_url: width: settings.logo_width | times: 2 | image_tag: loading: 'lazy', width: settings.logo_width, height: settings.logo_width | divided_by: settings.logo.aspect_ratio | round, alt: shop.name | escape }}
          {%- else -%}
            <span>{{ shop.name }}</span>
          {%- endif -%}
        </a>
        {%- if section.settings.tagline != blank -%}
          <p>{{ section.settings.tagline }}</p>
        {%- endif -%}
        {% render 'social-icons' %}
      </div>

      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'menu' -%}
            <div class="footer__col" {{ block.shopify_attributes }}>
              <h4>{{ block.settings.heading }}</h4>
              {%- if block.settings.menu != blank -%}
                <div class="footer__links">
                  {%- for link in block.settings.menu.links -%}
                    <a href="{{ link.url }}">{{ link.title }}</a>
                  {%- endfor -%}
                </div>
              {%- endif -%}
            </div>
          {%- when 'newsletter' -%}
            <div class="footer__col" {{ block.shopify_attributes }}>
              <h4>{{ block.settings.heading }}</h4>
              {%- if block.settings.subtext != blank -%}
                <p class="text-muted">{{ block.settings.subtext }}</p>
              {%- endif -%}
              {% form 'customer', class: 'newsletter__form mt-2' %}
                <input type="hidden" name="contact[tags]" value="newsletter">
                <input type="email" name="contact[email]" placeholder="Email address" required aria-label="Email address">
                <button type="submit" class="btn btn--primary btn--sm">Subscribe</button>
                {%- if form.posted_successfully? -%}
                  <p class="form-status form-status--success">Welcome to the crew. Check your inbox.</p>
                {%- elsif form.errors -%}
                  <p class="form-status form-status--error">{{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}.</p>
                {%- endif -%}
              {% endform %}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>

    <div class="footer__bottom">
      <div>© {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</div>
      <div>
        {%- for type in shop.enabled_payment_types -%}
          {{ type | payment_type_svg_tag: class: 'payment-icon' }}
        {%- endfor -%}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Festival fashion for performers, by performers."
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu column",
      "limit": 3,
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Join the crew" },
        { "type": "text", "id": "subtext", "label": "Subtext", "default": "Drops, lookbooks, and festival edits straight to your inbox." }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "menu", "settings": { "heading": "Shop" } },
      { "type": "menu", "settings": { "heading": "Help" } },
      { "type": "newsletter" }
    ]
  }
}
{% endschema %}
