<!doctype html>
<html lang="{{ request.locale.iso_code }}" class="no-js password-page">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="{{ settings.color_background }}">
    <link rel="canonical" href="{{ canonical_url }}">
    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
    <title>{{ shop.name }}{% if page_title %} &ndash; {{ page_title }}{% endif %}</title>
    {% if page_description %}<meta name="description" content="{{ page_description | escape }}">{% endif %}
    {% render 'meta-tags' %}

    {{ settings.font_heading | font_face: font_display: 'swap' }}
    {{ settings.font_body | font_face: font_display: 'swap' }}

    <style>
      :root {
        --color-bg: {{ settings.color_background }};
        --color-surface: {{ settings.color_surface }};
        --color-fg: {{ settings.color_foreground }};
        --color-muted: {{ settings.color_muted }};
        --color-border: {{ settings.color_border }};
        --color-accent: {{ settings.color_accent_primary }};
        --color-accent-2: {{ settings.color_accent_secondary }};
        --color-accent-3: {{ settings.color_accent_tertiary }};
        --gradient-holo: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-2) 50%, var(--color-accent-3) 100%);
        --font-heading: {{ settings.font_heading.family }}, {{ settings.font_heading.fallback_families }};
        --font-body: {{ settings.font_body.family }}, {{ settings.font_body.fallback_families }};
        --heading-weight: {{ settings.font_heading.weight }};
        --heading-transform: {% if settings.uppercase_headings %}uppercase{% else %}none{% endif %};
      }
    </style>

    {{ 'theme.css' | asset_url | stylesheet_tag }}
    <script>document.documentElement.classList.remove('no-js');</script>
    {{ content_for_header }}
  </head>
  <body class="template-password">
    {{ content_for_layout }}
    <script src="{{ 'theme.js' | asset_url }}" defer></script>
  </body>
</html>
