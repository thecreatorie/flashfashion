<div class="page-width section">
  <header class="collection-hero">
    <h1>{{ blog.title }}</h1>
  </header>

  {%- paginate blog.articles by 9 -%}
    <div class="product-grid product-grid--3">
      {%- for article in blog.articles -%}
        <a class="article-card" href="{{ article.url }}">
          <div class="article-card__media">
            {%- if article.image -%}
              {{ article.image | image_url: width: 1200 | image_tag: loading: 'lazy', widths: '600, 900, 1200', sizes: '(min-width: 800px) 33vw, 100vw', alt: article.title | escape }}
            {%- else -%}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          <div class="article-card__meta">{{ article.published_at | date: '%b %-d, %Y' }} · {{ article.author }}</div>
          <h3 class="article-card__title">{{ article.title }}</h3>
          {%- if article.excerpt or article.content -%}
            <p class="article-card__excerpt">{{ article.excerpt | default: article.content | strip_html | truncatewords: 22 }}</p>
          {%- endif -%}
        </a>
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <nav class="pagination">
        {%- for part in paginate.parts -%}
          {%- if part.is_link -%}<a href="{{ part.url }}">{{ part.title }}</a>{%- else -%}<span class="current">{{ part.title }}</span>{%- endif -%}
        {%- endfor -%}
      </nav>
    {%- endif -%}
  {%- endpaginate -%}
</div>

{% schema %}
{
  "name": "Blog",
  "settings": []
}
{% endschema %}
