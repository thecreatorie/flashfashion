<section class="section">
  <div class="page-width">
    <div class="image-text {% if section.settings.media_position == 'right' %}image-text--reverse{% endif %}" data-reveal>
      <div class="image-text__media">
        {%- if section.settings.image -%}
          {%- assign iwt_alt = section.settings.image.alt | default: section.settings.heading | escape -%}
          {%- assign iwt_url = section.settings.image | image_url: width: 1200 -%}
          {{ iwt_url | image_tag: loading: 'lazy', widths: '600, 900, 1200', sizes: '(min-width: 800px) 50vw, 100vw', alt: iwt_alt }}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
      <div class="image-text__content">
        {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
        {%- if section.settings.text != blank -%}<div class="text-muted">{{ section.settings.text }}</div>{%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <div>
            <a class="btn btn--primary" href="{{ section.settings.button_link | default: '#' }}">{{ section.settings.button_label }}</a>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image with text",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    {
      "type": "select",
      "id": "media_position",
      "label": "Media position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Performers first" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Engineered for the stage, the playa, and everything in between." },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Every Flash Fashion piece is designed by and tested with working performers — fire dancers, hoopers, DJs, drag artists. Reflective, breathable, and built to glow under blacklight or moonlight.</p>"
    },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Our story" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [{ "name": "Image with text" }]
}
{% endschema %}
