<section class="hero">
  <div class="hero-frame">
    {%- if section.settings.bg_video_url != blank -%}
      <video class="hero-bg" autoplay muted loop playsinline {% if section.settings.bg_image %}poster="{{ section.settings.bg_image | image_url: width: 1600 }}"{% endif %} preload="metadata" aria-hidden="true">
        <source src="{{ section.settings.bg_video_url }}" type="video/mp4">
      </video>
    {%- elsif section.settings.bg_image -%}
      {%- assign hero_bg_alt = section.settings.bg_image.alt | default: section.settings.heading | escape -%}
      {%- assign hero_bg_url = section.settings.bg_image | image_url: width: 2000 -%}
      <img class="hero-bg" src="{{ hero_bg_url }}" alt="{{ hero_bg_alt }}" loading="eager" />
    {%- endif -%}

    <div class="hero-content">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h1 style="margin-top: 22px;">{{ section.settings.heading }}</h1>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="lede">{{ section.settings.subheading }}</p>
      {%- endif -%}
      {%- if section.settings.button_label != blank or section.settings.button_label_2 != blank -%}
        <div class="hero-actions">
          {%- if section.settings.button_label != blank -%}
            <a href="{{ section.settings.button_link | default: '#' }}" class="btn btn--primary">{{ section.settings.button_label }} →</a>
          {%- endif -%}
          {%- if section.settings.button_label_2 != blank -%}
            <a href="{{ section.settings.button_link_2 | default: '#' }}" class="btn btn--ghost">{{ section.settings.button_label_2 }}</a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    {%- if section.settings.media_video_url != blank or section.settings.media_image -%}
      <div class="hero-media">
        {%- if section.settings.media_video_url != blank -%}
          <video autoplay muted loop playsinline {% if section.settings.media_image %}poster="{{ section.settings.media_image | image_url: width: 1200 }}"{% endif %} preload="metadata">
            <source src="{{ section.settings.media_video_url }}" type="video/mp4">
          </video>
        {%- else -%}
          {%- assign hero_m_alt = section.settings.media_image.alt | default: section.settings.heading | escape -%}
          {%- assign hero_m_url = section.settings.media_image | image_url: width: 1400 -%}
          <img src="{{ hero_m_url }}" alt="{{ hero_m_alt }}" loading="eager">
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "header", "content": "Background (behind text)" },
    { "type": "image_picker", "id": "bg_image", "label": "Background image" },
    { "type": "url", "id": "bg_video_url", "label": "Background video URL", "info": "MP4 hosted via Shopify Files. Plays muted, loops." },
    { "type": "header", "content": "Featured media (right column)" },
    { "type": "image_picker", "id": "media_image", "label": "Media image" },
    { "type": "url", "id": "media_video_url", "label": "Media video URL", "info": "Portrait video preferred." },
    { "type": "header", "content": "Copy" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "UV · Holo · Festival" },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>Turn your <em>fire fans</em><br>into <em>silk fans.</em></p>" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Slip-on silk covers, hand-sewn to fit your favorite fan frames — Lotus, Spider, Forged Creations®. Same grip, same feel, all silk." },
    { "type": "text", "id": "button_label", "label": "Primary button", "default": "Shop the drop" },
    { "type": "url", "id": "button_link", "label": "Primary link" },
    { "type": "text", "id": "button_label_2", "label": "Secondary button", "default": "Our story" },
    { "type": "url", "id": "button_link_2", "label": "Secondary link" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
