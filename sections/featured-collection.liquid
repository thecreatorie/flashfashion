<section class="section featured-collection">
  <div class="page-width">
    <div class="section-head">
      <div>
        {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        <h2 class="section-head__title">{{ section.settings.heading | default: section.settings.collection.title }}</h2>
        {%- if section.settings.intro != blank -%}<p class="section-head__intro">{{ section.settings.intro }}</p>{%- endif -%}
      </div>
      {%- if section.settings.collection != blank -%}
        <a class="btn btn--ghost btn--sm" href="{{ section.settings.collection.url }}">View all {% render 'icon-arrow' %}</a>
      {%- endif -%}
    </div>

    {%- liquid
      assign collection = section.settings.collection
      assign products = collection.products
      assign limit = section.settings.product_limit
      assign cols = section.settings.columns
    -%}

    <div class="product-grid product-grid--{{ cols }}" data-reveal>
      {%- if products.size > 0 -%}
        {%- for product in products limit: limit -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..limit) -%}
          <article class="product-card" data-ratio="{{ settings.card_image_ratio }}">
            <div class="product-card__media">{{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}</div>
            <div class="product-card__info">
              <h3 class="product-card__title">Sample product {{ i }}</h3>
              <div class="product-card__price">$0.00</div>
            </div>
          </article>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Latest drop" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Now glowing" },
    { "type": "textarea", "id": "intro", "label": "Intro" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "product_limit", "min": 4, "max": 16, "step": 4, "label": "Products to show", "default": 8 },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns (desktop)",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "4"
    }
  ],
  "presets": [{ "name": "Featured collection" }]
}
{% endschema %}
