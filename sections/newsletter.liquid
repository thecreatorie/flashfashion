<section class="section">
  <div class="page-width">
    <div class="newsletter" data-reveal>
      {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="text-gradient">{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.text != blank -%}<p class="text-muted" style="max-width:42ch; margin: 0.6rem auto 0;">{{ section.settings.text }}</p>{%- endif -%}
      {% form 'customer', class: 'newsletter__form' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input type="email" name="contact[email]" placeholder="Email address" required aria-label="Email address">
        <button type="submit" class="btn btn--primary">{{ section.settings.button_label | default: 'Subscribe' }}</button>
        {%- if form.posted_successfully? -%}
          <p class="form-status form-status--success" data-newsletter-status>Welcome to the crew. Check your inbox.</p>
        {%- elsif form.errors -%}
          <p class="form-status form-status--error" data-newsletter-status>{{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}.</p>
        {%- else -%}
          <p class="form-status" data-newsletter-status></p>
        {%- endif -%}
      {% endform %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Light it up" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Drops every full moon." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Be first on lookbooks, restocks, and members-only festival edits." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Subscribe" }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
