<section class="page-width">
  <div class="product">
    <div class="product-gallery" data-gallery-main>
      <div class="product-gallery__main">
        {%- if product.featured_image -%}
          {%- assign mp_alt = product.featured_image.alt | default: product.title | escape -%}
          {%- assign mp_url = product.featured_image | image_url: width: 1400 -%}
          {{ mp_url | image_tag: loading: 'eager', widths: '600, 900, 1200, 1400', sizes: '(min-width: 900px) 55vw, 100vw', alt: mp_alt }}
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
      {%- if product.images.size > 1 -%}
        <div class="product-gallery__thumbs">
          {%- for image in product.images -%}
            <button type="button" class="product-gallery__thumb" data-gallery-thumb data-image="{{ image | image_url: width: 1200 }}" aria-current="{% if forloop.first %}true{% else %}false{% endif %}" aria-label="Image {{ forloop.index }}">
              <img src="{{ image | image_url: width: 200 }}" loading="lazy" width="100" height="100" alt="">
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <div class="product-info">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'vendor' -%}
            {%- if product.vendor != blank -%}<div class="product-info__vendor" {{ block.shopify_attributes }}>{{ product.vendor }}</div>{%- endif -%}
          {%- when 'title' -%}
            <h1 class="product-info__title" {{ block.shopify_attributes }}>{{ product.title }}</h1>
          {%- when 'price' -%}
            <div class="product-info__price" {{ block.shopify_attributes }}>
              <span data-product-price>{{ product.selected_or_first_available_variant.price | money }}</span>
              <s data-product-compare {% if product.selected_or_first_available_variant.compare_at_price <= product.selected_or_first_available_variant.price %}hidden{% endif %}>
                {{ product.selected_or_first_available_variant.compare_at_price | money }}
              </s>
            </div>
          {%- when 'description' -%}
            <div class="product-info__desc" {{ block.shopify_attributes }}>{{ product.description }}</div>
          {%- when 'form' -%}
            <form class="product-form" data-product-form {{ block.shopify_attributes }} action="{{ routes.cart_add_url }}" method="post" enctype="multipart/form-data">
              <script type="application/json" data-product-json>{
                "id": {{ product.id }},
                "title": {{ product.title | json }},
                "options": {{ product.options | json }},
                "variants": [
                  {%- for v in product.variants -%}
                    {
                      "id": {{ v.id }},
                      "title": {{ v.title | json }},
                      "price": {{ v.price }},
                      "compare_at_price": {{ v.compare_at_price | default: 0 }},
                      "available": {{ v.available }},
                      "options": {{ v.options | json }},
                      "featured_image": {% if v.featured_image %}{ "src": {{ v.featured_image | image_url: width: 1400 | json }} }{% else %}null{% endif %}
                    }{% unless forloop.last %},{% endunless %}
                  {%- endfor -%}
                ]
              }</script>

              {%- unless product.has_only_default_variant -%}
                {%- for option in product.options_with_values -%}
                  <div class="variant-group">
                    <div class="variant-group__label">{{ option.name }}<span class="selected" data-option-selected="{{ forloop.index }}">{{ option.selected_value }}</span></div>
                    <div class="variant-options">
                      {%- for value in option.values -%}
                        <button type="button" class="variant-pill" data-option-pill data-option-position="{{ forloop.parentloop.index }}" data-option-value="{{ value | escape }}" data-checked="{% if value == option.selected_value %}true{% else %}false{% endif %}">
                          {{ value }}
                        </button>
                      {%- endfor -%}
                    </div>
                  </div>
                {%- endfor -%}
              {%- endunless -%}

              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

              <div class="flex gap-1 mt-2">
                <div class="qty">
                  <button type="button" data-qty-dec aria-label="Decrease">−</button>
                  <input type="number" name="quantity" min="1" value="1" aria-label="Quantity">
                  <button type="button" data-qty-inc aria-label="Increase">+</button>
                </div>
                <button type="submit" class="btn btn--primary btn--full" data-product-submit {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}>
                  <span data-product-submit-label>{% if product.selected_or_first_available_variant.available %}Add to bag{% else %}Sold out{% endif %}</span>
                </button>
              </div>
            </form>
          {%- when 'meta' -%}
            <ul class="product-meta" {{ block.shopify_attributes }}>
              {%- if block.settings.show_shipping -%}
                <li class="product-meta__item">{% render 'icon-shipping' %} Free shipping over $150</li>
              {%- endif -%}
              {%- if block.settings.show_returns -%}
                <li class="product-meta__item">{% render 'icon-returns' %} 30-day returns</li>
              {%- endif -%}
              {%- if block.settings.show_secure -%}
                <li class="product-meta__item">{% render 'icon-secure' %} Secure checkout</li>
              {%- endif -%}
            </ul>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{%- assign related = collections[product.collections.first.handle].products | default: collections.all.products -%}
{%- if related.size > 1 -%}
  <section class="section">
    <div class="page-width">
      <div class="section-head"><h2>You might also like</h2></div>
      <div class="product-grid product-grid--4">
        {%- assign printed = 0 -%}
        {%- for p in related -%}
          {%- if p.id != product.id and printed < 4 -%}
            {% render 'product-card', product: p %}
            {%- assign printed = printed | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Product",
  "blocks": [
    { "type": "vendor", "name": "Vendor", "limit": 1, "settings": [] },
    { "type": "title", "name": "Title", "limit": 1, "settings": [] },
    { "type": "price", "name": "Price", "limit": 1, "settings": [] },
    { "type": "description", "name": "Description", "limit": 1, "settings": [] },
    { "type": "form", "name": "Buy form", "limit": 1, "settings": [] },
    {
      "type": "meta",
      "name": "Trust badges",
      "limit": 1,
      "settings": [
        { "type": "checkbox", "id": "show_shipping", "label": "Show shipping", "default": true },
        { "type": "checkbox", "id": "show_returns", "label": "Show returns", "default": true },
        { "type": "checkbox", "id": "show_secure", "label": "Show secure checkout", "default": true }
      ]
    }
  ]
}
{% endschema %}
