{%- if section.blocks.size > 0 -%}
  <div class="announcement" role="region" aria-label="Announcements" data-announcement>
    <div class="announcement__inner">
      {%- for block in section.blocks -%}
        {%- if block.settings.link != blank -%}
          <a href="{{ block.settings.link }}" {{ block.shopify_attributes }}>{{ block.settings.text }}</a>
        {%- else -%}
          <span {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
        {%- endif -%}
        {%- unless forloop.last -%}<span aria-hidden="true">·</span>{%- endunless -%}
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "max_blocks": 5,
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Free shipping on orders over $150" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "message", "settings": { "text": "Free shipping on orders over $150" } },
      { "type": "message", "settings": { "text": "Made for performers. Built for the desert." } }
    ]
  },
  "presets": [
    { "name": "Announcement bar" }
  ]
}
{% endschema %}
