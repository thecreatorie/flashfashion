<div class="password-shell">
  <div class="password-shell__inner">
    <span class="eyebrow">Coming soon</span>
    <h1 class="text-gradient">{{ section.settings.heading | default: shop.name }}</h1>
    <p>{{ section.settings.subheading }}</p>

    {% form 'customer', class: 'password-shell__form' %}
      <input type="hidden" name="contact[tags]" value="prospect, password page">
      <input type="email" name="contact[email]" placeholder="Email address" required aria-label="Email address">
      <button type="submit" class="btn btn--primary">Notify me</button>
    {% endform %}

    <div class="mt-4" style="display:flex; gap:1rem; justify-content:center; align-items:center; color: var(--color-muted); font-size:0.85rem">
      <a href="#" onclick="document.querySelector('[data-password-modal]').setAttribute('open',''); return false;" style="text-decoration:underline; text-underline-offset:3px">Enter with password</a>
    </div>
  </div>
</div>

<dialog data-password-modal style="background: var(--color-bg); color: var(--color-fg); border: 1px solid var(--color-border); max-width: 420px; padding: 2rem; border-radius: 8px;">
  <h3 class="mb-2">Enter password</h3>
  {% form 'storefront_password' %}
    <div class="field"><label>Password</label><input type="password" name="password" required></div>
    <div class="flex gap-1 mt-2">
      <button type="submit" class="btn btn--primary">Enter</button>
      <button type="button" class="btn btn--ghost" onclick="this.closest('dialog').removeAttribute('open')">Cancel</button>
    </div>
    {%- if form.errors -%}<p class="form-status form-status--error">{{ form.errors.messages.form }}</p>{%- endif -%}
  {% endform %}
</dialog>

{% schema %}
{
  "name": "Password",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Flash Fashion" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Festival armor for performers, by performers. Drop arriving soon." }
  ]
}
{% endschema %}
