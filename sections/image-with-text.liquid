<section class="section-tight">
  <div class="page-width page-width--narrow">
    <div class="editorial-split {% if section.settings.media_position == 'right' %}editorial-split--reverse{% endif %}">
      <div class="image-col">
        {%- if section.settings.video_url != blank -%}
          <video autoplay muted loop playsinline {% if section.settings.image %}poster="{{ section.settings.image | image_url: width: 1200 }}"{% endif %} preload="metadata">
            <source src="{{ section.settings.video_url }}" type="video/mp4">
          </video>
        {%- elsif section.settings.image -%}
          {%- assign iwt_alt = section.settings.image.alt | default: section.settings.heading | escape -%}
          {%- assign iwt_url = section.settings.image | image_url: width: 1200 -%}
          <img src="{{ iwt_url }}" alt="{{ iwt_alt }}" loading="lazy">
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
      <div class="text-col">
        {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
        {%- if section.settings.text != blank -%}{{ section.settings.text }}{%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <a class="btn-link" href="{{ section.settings.button_link | default: '#' }}">{{ section.settings.button_label }} →</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Editorial split",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "url", "id": "video_url", "label": "Video URL (optional)", "info": "MP4 hosted via Shopify Files. Replaces the image when present." },
    {
      "type": "select",
      "id": "media_position",
      "label": "Media position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "In motion" },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>Silk that<br><em>moves with you.</em></p>" },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Every silk fan is hand-sewn. The iridescent crown is stitched on individually. We don't print and we don't mass-produce — patience is part of the recipe.</p><p>You'll get a pair that no one else has, ever, exactly.</p>"
    },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Our story" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [{ "name": "Editorial split" }]
}
{% endschema %}
