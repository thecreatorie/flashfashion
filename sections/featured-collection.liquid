<section class="section featured-collection">
  <div class="page-width">
    <div class="section-head">
      <div class="left">
        {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        <h2>{{ section.settings.heading | default: section.settings.collection.title }}</h2>
      </div>
      <div class="right">
        {%- if section.settings.intro != blank -%}<p>{{ section.settings.intro }}</p>{%- endif -%}
        {%- if section.settings.collection != blank -%}
          <a class="btn-link" href="{{ section.settings.collection.url }}">Shop all →</a>
        {%- endif -%}
      </div>
    </div>

    {%- liquid
      assign collection = section.settings.collection
      if collection != blank and collection.products.size > 0
        assign products = collection.products
      else
        assign products = collections.all.products
      endif
      assign limit = section.settings.product_limit
      assign cols = section.settings.columns
    -%}

    <div class="product-grid {% if cols == '2' %}product-grid--2{% endif %}">
      {%- if products.size > 0 -%}
        {%- for product in products limit: limit -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..limit) -%}
          <div class="product-card" data-ratio="{{ settings.card_image_ratio }}">
            <div class="product-card__media">{{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}</div>
            <div class="product-card__info">
              <div class="product-card__info-main">
                <h3 class="product-card__title">Sample product {{ i }}</h3>
                <div class="product-card__price">$0.00</div>
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Silk fans" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Same grip. Silk Flow." },
    { "type": "textarea", "id": "intro", "label": "Intro", "default": "Hand-sewn silk covers that fit Lotus, Spider, and Forged Creations® frames — 5 wicks, Russian grip." },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "product_limit", "min": 4, "max": 16, "step": 4, "label": "Products to show", "default": 4 },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns (desktop)",
      "options": [
        { "value": "2", "label": "2 (large)" },
        { "value": "auto", "label": "Auto (responsive)" }
      ],
      "default": "auto"
    }
  ],
  "presets": [{ "name": "Featured collection" }]
}
{% endschema %}
